/**
 * 全局样式
 */
page {
  background-color: #f3f4f6;
}
.container {
  padding: 24rpx;
  min-height: 100vh;
}
.card {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.08);
  padding: 32rpx;
  margin-bottom: 24rpx;
}
.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #111827;
  margin-bottom: 20rpx;
}
.button-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}
.button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 18rpx;
  background: linear-gradient(90deg, #6366f1, #4f46e5);
  color: #ffffff;
  font-size: 28rpx;
}
.nav-link {
  color: #4338ca;
  font-size: 28rpx;
}
