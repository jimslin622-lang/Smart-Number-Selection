/* 容器 */
.container {
  padding: 0 24rpx calc(120rpx + env(safe-area-inset-bottom));
  background: #f3f4f6;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 顶部滚动提示条 */
.top-scroll-bar {
  background: linear-gradient(135deg, #1e40af, #3b82f6);
  padding: 16rpx 0;
  margin: 0 -24rpx 24rpx -24rpx;
  overflow: hidden;
}
.scroll-wrapper {
  display: flex;
  white-space: nowrap;
}
.scroll-content {
  display: inline-flex;
  align-items: center;
  gap: 32rpx;
  padding: 0 24rpx;
  animation: scroll-left 15s linear infinite;
}
.scroll-item {
  font-size: 24rpx;
  color: #ffffff;
  white-space: nowrap;
  flex-shrink: 0;
}
@keyframes scroll-left {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-50%);
  }
}

/* Logo区域 */
.logo-section {
  text-align: center;
  padding: 30rpx 0;
}
.logo-outer {
  position: relative;
  display: inline-block;
}
.logo-inner {
  width: 128rpx;
  height: 128rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #7c3aed, #a855f7, #6366f1);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(124, 58, 237, 0.3);
}
.logo-dots {
  display: flex;
  gap: 4rpx;
  align-items: center;
}
.col {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.col-mid {
  margin-top: 6rpx;
}
.dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}
.dot-white { background: rgba(255,255,255,0.9); }
.dot-white-lg { width: 24rpx; height: 24rpx; background: rgba(255,255,255,1); }
.dot-white-sm { background: rgba(255,255,255,0.8); }
.dot-cyan { background: rgba(103,232,249,0.9); }
.dot-yellow { background: rgba(253,224,71,0.9); }
.dot-pink { background: rgba(249,168,212,0.9); }
.logo-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #fcd34d, #fb923c);
  border-radius: 50%;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(251,146,60,0.4);
}
.logo-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #7c3aed, #a855f7, #6366f1);
  -webkit-background-clip: text;
  color: transparent;
  margin-top: 20rpx;
}
.logo-subtitle {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

/* 卡片通用 */
.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.card-header {
  margin-bottom: 20rpx;
}
.card-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #374151;
}

/* 提示框 */
.tip-box {
  background: #fffbeb;
  border: 1rpx solid #fde68a;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}
.tip-text {
  font-size: 24rpx;
  color: #b45309;
  line-height: 1.6;
}

/* 警告提示框 */
.warning-box {
  background: #fef2f2;
  border: 1rpx solid #fecaca;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}
.warning-text {
  font-size: 24rpx;
  color: #dc2626;
  line-height: 1.6;
}

/* 数字模板网格 */
.type-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}
.type-item {
  border-radius: 16rpx;
  padding: 16rpx 6rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 170rpx;
  border: 2rpx solid transparent;
  background: #f9fafb;
}
.type-item.active {
  background: #ecfdf5;
  border-color: #22c55e;
}
.type-item.active .type-name {
  color: #15803d;
}
.type-item:active {
  opacity: 0.8;
}

/* 网格图标通用 */
.type-icon-wrapper {
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}
.lottery-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}
.lottery-icon-sm {
  width: 40rpx;
  height: 40rpx;
}
.lottery-icon-text {
  font-size: 22rpx;
  font-weight: bold;
  color: #ffffff;
}
.lottery-icon-text-sm {
  font-size: 18rpx;
}
.lottery-icon-lhc { background: linear-gradient(135deg, #10b981, #059669); }
.lottery-icon-ssq { background: linear-gradient(135deg, #ef4444, #3b82f6); }
.lottery-icon-dlt { background: linear-gradient(135deg, #f59e0b, #ea580c); }
.lottery-icon-qlc { background: linear-gradient(135deg, #ec4899, #fbbf24, #06b6d4); }
.lottery-icon-qxc { background: linear-gradient(135deg, #6366f1, #8b5cf6); }
.lottery-icon-fc3d { background: linear-gradient(135deg, #8b5cf6, #7c3aed); }
.lottery-icon-pl3 { background: linear-gradient(135deg, #22c55e, #14b8a6); }
.lottery-icon-pl5 { background: linear-gradient(135deg, #14b8a6, #06b6d4); }
.lottery-icon-kl8 { background: linear-gradient(135deg, #f97316, #ea580c); }

/* 组合A: 绿色圆圈+6 */
.type-icon-circle-lhc {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #10b981, #059669);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}
.type-icon-num {
  font-size: 24rpx;
  font-weight: bold;
  color: #ffffff;
}

/* 组合B: 主区+副区 */
.type-icon-dots {
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.dot-icon-red {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ef4444, #dc2626);
  box-shadow: 0 2rpx 6rpx rgba(239,68,68,0.3);
}
.dot-icon-blue {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  box-shadow: 0 2rpx 6rpx rgba(59,130,246,0.3);
}

/* 组合C: 橙色圆圈+大 */
.type-icon-circle-dlt {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f59e0b, #ea580c);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}
.type-icon-text {
  font-size: 22rpx;
  font-weight: bold;
  color: #ffffff;
}

/* 组合D: 渐变圆圈 */
.type-icon-circle-qlc {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ec4899, #fbbf24, #06b6d4);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

/* 组合E: 紫色圆圈+7 */
.type-icon-circle-qxc {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

/* 三位数字: 三个紫方块 */
.type-icon-squares {
  display: flex;
  align-items: center;
  gap: 4rpx;
}
.square-purple {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
  background: linear-gradient(135deg, #8b5cf6, #7c3aed);
  box-shadow: 0 2rpx 4rpx rgba(139,92,246,0.3);
}
.square-purple.up {
  margin-bottom: 8rpx;
}

/* 三位组合: 三个绿竖条 */
.type-icon-bars {
  display: flex;
  align-items: center;
  gap: 4rpx;
}
.bar-green {
  width: 16rpx;
  height: 32rpx;
  border-radius: 4rpx;
  background: linear-gradient(180deg, #22c55e, #16a34a);
  box-shadow: 0 2rpx 4rpx rgba(34,197,94,0.3);
}

/* 五位组合: 五个青竖条 */
.bar-teal {
  width: 12rpx;
  height: 28rpx;
  border-radius: 4rpx;
  background: linear-gradient(180deg, #14b8a6, #06b6d4);
  box-shadow: 0 2rpx 4rpx rgba(20,184,166,0.3);
}

/* 十位组合: 橙色圆圈+8 */
.type-icon-circle-kl8 {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f97316, #ea580c);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

