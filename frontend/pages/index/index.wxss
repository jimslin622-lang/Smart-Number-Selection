/* ====== 最新示例号码区域 ====== */
.latest-numbers-area {
  background: linear-gradient(135deg, #f8fafc, #f1f5f9);
  border-radius: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #e2e8f0;
}

/* 通用玩法：大号渐变球 */
.generic-numbers {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 14rpx;
}
.glow-ball {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.15);
  position: relative;
}
.glow-ball::after {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 14rpx;
  width: 20rpx;
  height: 12rpx;
  background: rgba(255,255,255,0.35);
  border-radius: 50%;
  transform: rotate(-20deg);
}
.glow-ball-text {
  font-size: 28rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1;
  z-index: 1;
}

/* 随机生成按钮 */
.random-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.random-btn {
  flex: 1;
  background: linear-gradient(135deg, #22c55e, #16a34a);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(34,197,94,0.3);
}
.random-btn-secondary {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  box-shadow: 0 4rpx 16rpx rgba(59,130,246,0.24);
}
.random-btn:active {
  opacity: 0.9;
}
.random-icon {
  font-size: 34rpx;
}
.random-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #ffffff;
}
.random-arrow {
  font-size: 32rpx;
  color: rgba(255,255,255,0.8);
}

