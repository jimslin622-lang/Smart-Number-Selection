<view class="container">
  <!-- 用户信息 -->
  <view class="profile-header">
    <view class="avatar">
      <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill"></image>
      <text wx:else class="avatar-icon">👤</text>
    </view>
    <text class="profile-name">{{nickname}}</text>
    <text class="profile-desc">欢迎使用</text>
  </view>

  <!-- 统计数据 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-value">{{stats.total}}</text>
      <text class="stat-label">总记录</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{stats.starred}}</text>
      <text class="stat-label">收藏</text>
    </view>
  </view>

  <!-- 玩法分布 -->
  <view class="section" wx:if="{{stats.byLottery.length > 0}}">
    <text class="section-title">玩法分布</text>
    <view class="lottery-dist">
      <view class="dist-item" wx:for="{{stats.byLottery}}" wx:key="lottery_code">
        <text class="dist-name">{{item.lottery_code}}</text>
        <view class="dist-bar-bg">
          <view class="dist-bar" style="width: {{item.count / stats.total * 100}}%;"></view>
        </view>
        <text class="dist-count">{{item.count}}注</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goRecord">
      <text class="menu-icon">📝</text>
      <text class="menu-text">数字记录</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="exportAll">
      <text class="menu-icon">📤</text>
      <text class="menu-text">导出全部记录</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="clearAll" wx:if="{{stats.total > 0}}">
      <text class="menu-icon">🗑️</text>
      <text class="menu-text menu-danger">清空所有记录</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="showAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <text class="disclaimer">本工具仅供娱乐参考，不对应任何现实业务场景</text>

  <tabbar />
</view>
