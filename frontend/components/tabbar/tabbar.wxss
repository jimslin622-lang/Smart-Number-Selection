.tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(100rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  display: flex;
  align-items: center;
  border-top: 1rpx solid #e5e7eb;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.04);
  z-index: 999;
  box-sizing: content-box;
}

.tabbar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  gap: 4rpx;
}

.tabbar-icon {
  width: 40rpx;
  height: 40rpx;
}

.tabbar-text {
  font-size: 20rpx;
  color: #9ca3af;
  line-height: 1;
}

.tabbar-item.active .tabbar-text {
  color: #22c55e;
  font-weight: 500;
}