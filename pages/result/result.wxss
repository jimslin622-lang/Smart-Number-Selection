.container {
  padding: 24rpx;
  background: #f3f4f6;
  min-height: 100vh;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.header {
  margin-bottom: 24rpx;
}
.title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1f2937;
}

/* 模板筛选 */
.type-filter-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.filter-label {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 16rpx;
}
.type-scroll {
  width: 100%;
  white-space: nowrap;
}
.type-filter-list {
  display: flex;
  gap: 12rpx;
  width: max-content;
}
.type-chip {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 24rpx;
  white-space: nowrap;
}
.type-chip.active {
  background: #22c55e;
  color: #ffffff;
  font-weight: 600;
}

/* 期数选择 */
.period-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.period-label {
  font-size: 26rpx;
  color: #6b7280;
  white-space: nowrap;
}
.period-btns {
  display: flex;
  gap: 12rpx;
  flex: 1;
}
.period-btn {
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #6b7280;
  background: #f3f4f6;
  text-align: center;
}
.period-btn.active {
  background: #22c55e;
  color: #ffffff;
}

/* 规则 */
.rules-card {
  background: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  padding: 0;
  overflow: hidden;
}
.rules-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
}
.rules-header:active {
  background: #f9fafb;
}
.rules-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #374151;
}
.rules-toggle {
  font-size: 26rpx;
  color: #9ca3af;
}
.rules-content {
  padding: 0 28rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.rule-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}
.rule-dot {
  color: #22c55e;
  font-size: 28rpx;
  line-height: 1.4;
}
.rule-text {
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.5;
  flex: 1;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.result-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.result-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.result-period-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.result-tag {
  font-size: 20rpx;
  color: #dc2626;
  background: #fef2f2;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}
.result-period {
  font-size: 24rpx;
  color: #9ca3af;
}
.result-date {
  font-size: 24rpx;
  color: #9ca3af;
}
.result-numbers {
  background: linear-gradient(135deg, #f8fafc, #f1f5f9);
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 14rpx;
  border: 1rpx solid #e2e8f0;
}
.result-numbers .glow-ball {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.15);
  position: relative;
  background: linear-gradient(135deg, #ef4444, #b91c1c);
}
.result-numbers .glow-ball::after {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 14rpx;
  width: 18rpx;
  height: 10rpx;
  background: rgba(255,255,255,0.35);
  border-radius: 50%;
  transform: rotate(-20deg);
}
.result-numbers .glow-ball-text {
  font-size: 26rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1;
  z-index: 1;
}

.result-count {
  text-align: center;
  padding: 24rpx 0;
}
.result-count-text {
  font-size: 26rpx;
  color: #9ca3af;
}
