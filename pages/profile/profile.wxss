.container {
  padding: 24rpx;
  background: #f3f4f6;
  min-height: 100vh;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 用户信息 */
.profile-header {
  text-align: center;
  padding: 60rpx 0;
}
.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #dcfce7;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
  overflow: hidden;
}
.avatar-img {
  width: 100%;
  height: 100%;
}
.avatar-icon {
  font-size: 64rpx;
  color: #22c55e;
}
.profile-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 8rpx;
}
.profile-desc {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
}

/* 统计卡片 */
.stats-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.stat-item {
  flex: 1;
  text-align: center;
}
.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 8rpx;
}
.stat-label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
}
.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e5e7eb;
}

/* 玩法分布 */
.section {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 16rpx;
}
.lottery-dist {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.dist-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.dist-name {
  width: 100rpx;
  font-size: 24rpx;
  color: #6b7280;
  flex-shrink: 0;
}
.dist-bar-bg {
  flex: 1;
  height: 20rpx;
  background: #f3f4f6;
  border-radius: 10rpx;
  overflow: hidden;
}
.dist-bar {
  height: 100%;
  background: linear-gradient(90deg, #22c55e, #16a34a);
  border-radius: 10rpx;
  transition: width 0.3s;
}
.dist-count {
  width: 60rpx;
  font-size: 22rpx;
  color: #9ca3af;
  text-align: right;
  flex-shrink: 0;
}

/* 菜单 */
.menu-list {
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  margin-bottom: 24rpx;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-item:active {
  background: #f9fafb;
}
.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}
.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #374151;
}
.menu-danger {
  color: #dc2626;
}
.menu-arrow {
  font-size: 32rpx;
  color: #d1d5db;
}

.disclaimer {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #9ca3af;
  padding: 16rpx 0;
}
